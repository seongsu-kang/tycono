{
  "name": "tycono",
  "version": "0.1.96-beta.43",
  "description": "Build an AI company. Watch them work.",
  "type": "module",
  "bin": {
    "tycono": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/api/src/",
    "src/api/package.json",
    "src/shared/",
    "src/tui/",
    "src/web/dist/",
    "templates/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev --prefix src/api",
    "dev:web": "npm run dev --prefix src/web",
    "build": "npm run build:web && npm run build:forge",
    "build:web": "npm run build --prefix src/web",
    "build:forge": "cp node_modules/tyconoforge/dist/tyconoforge.js src/web/dist/tyconoforge.js",
    "typecheck": "npm run typecheck:api && npm run typecheck:web",
    "typecheck:api": "cd src/api && npx tsc --noEmit",
    "typecheck:web": "cd src/web && npx tsc --noEmit",
    "start": "node bin/cli.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "glob": "^11.0.1",
    "gray-matter": "^4.0.3",
    "ink": "^5.2.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.6",
    "react": "^18.3.1",
    "tsx": "^4.19.3",
    "tyconoforge": "^0.1.0-beta.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "ai",
    "tycono",
    "company",
    "organization",
    "roles",
    "claude",
    "agent",
    "multi-agent",
    "agentic",
    "local-first"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seongsu-kang/tycono.git"
  },
  "homepage": "https://github.com/seongsu-kang/tycono#readme"
}
