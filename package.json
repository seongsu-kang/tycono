{
  "name": "tycono",
  "version": "0.3.45-beta.1",
  "description": "Your AI team for solo builders. Run a full company with AI agents.",
  "type": "module",
  "bin": {
    "tycono": "./bin/cli.js"
  },
  "workspaces": [
    "packages/server",
    "packages/pixel",
    "packages/tui",
    "packages/plugin"
  ],
  "files": [
    "bin/",
    "packages/server/src/",
    "packages/server/templates/",
    "packages/server/bin/",
    "packages/tui/src/",
    "packages/pixel/dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "tsx watch packages/server/src/api/src/server.ts",
    "dev:web": "npm run dev --prefix packages/pixel",
    "build": "npm run build --prefix packages/pixel",
    "typecheck": "npm run typecheck:api && npm run typecheck:web",
    "typecheck:api": "cd packages/server/src/api && npx tsc --noEmit",
    "typecheck:web": "cd packages/pixel && npx tsc --noEmit",
    "start": "node bin/cli.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "ink": "^5.2.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.6",
    "react": "^18.3.1",
    "tsx": "^4.19.3",
    "tyconoforge": "^0.1.0-beta.0",
    "yaml": "^2.7.0",
    "yoga-layout": "3.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "@types/react": "^19.2.14",
    "react-devtools-core": "^4.28.5",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "ai",
    "tycono",
    "company",
    "organization",
    "roles",
    "claude",
    "agent",
    "multi-agent",
    "agentic",
    "local-first"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seongsu-kang/tycono.git"
  },
  "homepage": "https://github.com/seongsu-kang/tycono#readme"
}
