{
  "name": "tycono-server",
  "version": "0.2.9-beta.3",
  "description": "Tycono AI team orchestration server. Dispatch, supervise, and observe AI agents working as a team.",
  "type": "module",
  "bin": {
    "tycono-server": "bin/cli.js"
  },
  "files": [
    "bin/",
    "src/api/package.json",
    "src/api/src/",
    "src/core/",
    "src/shared/",
    "templates/",
    "presets/",
    "src/ui/dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "dev": "tsx watch src/api/src/server.ts",
    "test": "vitest run src/api/src/tests/smoke.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.19.3",
    "vite": "^8.0.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "ai",
    "tycono",
    "agent",
    "multi-agent",
